  # ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
HOST=0.0.0.0
NODE_PORT=7000
NODE_ENV=development

# ─────────────────────────────────────────
# Database (MySQL)
# ─────────────────────────────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=changchana
DATABASE_USERNAME=root
DATABASE_PASSWORD=
DATABASE_SSL=false
# Optional
DATABASE_QUERY_DEBUG=false
DATABASE_POOL_MAX=10

# ─────────────────────────────────────────
# Auth / JWT
# ─────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
BASIC_AUTHORIZATION=your_basic_auth_token_here

# ─────────────────────────────────────────
# Omise Payment Gateway
# ─────────────────────────────────────────
# Get keys from https://dashboard.omise.co/test/api-keys
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxxx
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxxx
# PromptPay QR expiry in seconds (default: 900 = 15 min)
OMISE_PROMPT_PAY_EXPIRE=900

# ─────────────────────────────────────────
# File Storage (DigitalOcean Spaces / S3)
# ─────────────────────────────────────────
DO_SPACE_ACCESS_KEY=your_do_access_key
DO_SPACE_SECRET_KEY=your_do_secret_key
DO_SPACE_ENDPOINT=sgp1.digitaloceanspaces.com
DO_SPACE_BUCKET=your-bucket-name
DO_SPACE_DIRECTORY=uploads
DO_SPACE_CDN=https://your-bucket-name.sgp1.cdn.digitaloceanspaces.com

# ─────────────────────────────────────────
# OTP Service (ThaiBulk SMS)
# ─────────────────────────────────────────
THAIBULK_OTP_ENPOINT=https://api.thaibulk.com/v1/otp/send
THAIBULK_API_KEY=your_thaibulk_api_key
THAIBULK_API_SECRET=your_thaibulk_api_secret

# ─────────────────────────────────────────
# Push Notifications (OneSignal)
# ─────────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# ─────────────────────────────────────────
# App URLs
# ─────────────────────────────────────────
WEBSITE_ENDPOINT_URL=http://localhost:7000
